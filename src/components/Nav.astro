---
const links = [
  { href: '#hero',      label: 'about' },
  { href: '#skills',     label: 'skills' },
  { href: '#experience', label: 'experience' },
  { href: '#projects',   label: 'projects' },
  { href: '#education',  label: 'education' },
  { href: '#contact',    label: 'contact' },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between
            px-14 py-4 bg-surface/95 backdrop-blur-md border-b border-border">
  <a href="#hero" class="font-mono text-sm text-accent tracking-wide">p_y_t_h_e_c.dev</a>
  <ul class="hidden md:flex gap-10 list-none">
    {links.map(link => (
      <li>
        <a href={link.href}
            class="font-mono text-xs text-muted tracking-widest hover:text-primary transition-colors">
          {link.label}
        </a>
      </li>
    ))}
  </ul>
</nav>

<script>
  const nav = document.querySelector('nav');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      nav?.classList.add('scrolled');
    } else {
      nav?.classList.remove('scrolled');
    }
  });
</script>

<style>
  nav.scrolled {
    border-bottom-color: rgba(255,255,255,0.12);
  }
</style>